# Copy to .env for client demos (SentinelGate sandbox — credentials from SentinelGate)

DATABASE_URL=
DIRECT_URL=

JWT_SECRET=demo-jwt-change-me
JWT_REFRESH_SECRET=demo-refresh-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Required for demo deposits (card → SentinelGate hosted checkout)
SENTINELGATE_API_KEY=sg_key_...
SENTINELGATE_API_SECRET=sg_secret_...
SENTINELGATE_WEBHOOK_SECRET=your_webhook_secret
API_PUBLIC_URL=http://localhost:3001
SENTINELGATE_SUCCESS_URL=http://localhost:3000/wallet/deposit/success
SENTINELGATE_CANCEL_URL=http://localhost:3000/wallet/deposit/cancel
# Checkout currency defaults to USD; override only if needed:
# SENTINELGATE_CURRENCY=GHS

# Must be false or unset when using SentinelGate (do not use instant simulation in payment demos)
PAYMENT_SIMULATION_INSTANT=false

GAME_ENGINE_ENABLED=true

# Demo account: npm run seed:demo
