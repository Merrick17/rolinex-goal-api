generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique @db.VarChar(20)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  balance       Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("USD") @db.VarChar(3)
  accountFrozen Boolean  @default(false) @map("account_frozen")
  referralCode  String?  @unique @map("referral_code") @db.VarChar(20)
  referredBy    String?  @map("referred_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  bets          Bet[]
  transactions  Transaction[]
  referralsMade User[]    @relation("UserReferrals")
  referrer      User?     @relation("UserReferrals", fields: [referredBy], references: [id])

  @@map("users")
}

model Round {
  id             String      @id @default(uuid())
  roundNumber    Int         @unique @map("round_number")
  crashPoint     Decimal     @map("crash_point") @db.Decimal(10, 2)
  crashType      CrashType   @map("crash_type")
  serverSeedHash String      @map("server_seed_hash") @db.VarChar(64)
  serverSeed     String?     @map("server_seed") @db.Text
  status         RoundStatus @default(waiting)
  startedAt      DateTime?   @map("started_at")
  endedAt        DateTime?   @map("ended_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  bets Bet[]

  @@map("rounds")
}

model Bet {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  roundId           String    @map("round_id")
  amount            Decimal   @db.Decimal(10, 2)
  autoCashout       Decimal?  @map("auto_cashout") @db.Decimal(10, 2)
  cashoutMultiplier Decimal?  @map("cashout_multiplier") @db.Decimal(10, 2)
  winnings          Decimal?  @db.Decimal(12, 2)
  status            BetStatus @default(active)
  createdAt         DateTime  @default(now()) @map("created_at")
  cashedOutAt       DateTime? @map("cashed_out_at")

  user  User  @relation(fields: [userId], references: [id])
  round Round @relation(fields: [roundId], references: [id])

  @@map("bets")
}

model Transaction {
  id           String              @id @default(uuid())
  userId       String              @map("user_id")
  type         TransactionType
  amount       Decimal             @db.Decimal(12, 2)
  balanceAfter Decimal             @map("balance_after") @db.Decimal(12, 2)
  referenceId  String?             @map("reference_id")
  txStatus     TransactionTxStatus @default(completed) @map("tx_status")
  createdAt    DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model WebhookDelivery {
  id        String   @id @default(uuid())
  eventKey  String   @unique @map("event_key") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("webhook_deliveries")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

enum CrashType {
  post
  miss
  save
}

enum RoundStatus {
  waiting
  flying
  crashed
}

enum BetStatus {
  active
  won
  lost
}

enum TransactionTxStatus {
  pending
  completed
  failed
}

enum TransactionType {
  deposit
  withdraw
  bet
  win
  admin_credit
  admin_debit
}
