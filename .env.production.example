# Production — copy to .env (Docker, Render, VPS, etc.)
# Generate secrets: openssl rand -base64 48

NODE_ENV=production
PORT=3001

# Postgres (app pooler + direct URL for migrations; can be the same on single host)
DATABASE_URL=postgresql://USER:PASSWORD@db-host:5432/prolinex?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@db-host:5432/prolinex?sslmode=require

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend origin(s), comma-separated — no wildcard in production
CORS_ORIGIN=https://app.yourdomain.com

# Public API URL (webhooks + SentinelGate callback)
API_PUBLIC_URL=https://api.yourdomain.com

# SentinelGate — required when NODE_ENV=production
SENTINELGATE_API_KEY=
SENTINELGATE_API_SECRET=
SENTINELGATE_WEBHOOK_SECRET=
SENTINELGATE_SUCCESS_URL=https://app.yourdomain.com/wallet/deposit/success
SENTINELGATE_CANCEL_URL=https://app.yourdomain.com/wallet/deposit/cancel
# SENTINELGATE_CURRENCY=USD
# SENTINELGATE_BASE_URL=https://sentinelgate.biz

# Must be false or unset in production
PAYMENT_SIMULATION_INSTANT=false

# Manual payout webhooks (optional)
PAYMENT_WEBHOOK_SECRET=
PAYMENT_BASE_URL=

# Multi-instance / Socket.IO scaling
REDIS_URL=redis://redis:6379

GAME_ENGINE_ENABLED=true
ENABLE_SWAGGER=false
ADMIN_API_KEY=
