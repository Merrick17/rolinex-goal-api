# ─── ProlineX crash-game API (prolinex-goal-api) ──────────────────────────────
# See docs/ARCHITECTURE.md for current game-only architecture

# Database (Supabase: use pooler URL for app, direct port 5432 for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
# Access / refresh token lifetime (jsonwebtoken timespan: 15m, 7d, 3600, etc.)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Payments — SentinelGate (card deposits) — https://github.com/SentinelGateLLC/SentinelgateDocumentation
# Client "API KEY" → SENTINELGATE_API_KEY | "API Secret" → SENTINELGATE_API_SECRET | "API Webhook" → SENTINELGATE_WEBHOOK_SECRET
SENTINELGATE_API_KEY=
SENTINELGATE_API_SECRET=
SENTINELGATE_WEBHOOK_SECRET=
# Public API URL used to build callback: {API_PUBLIC_URL}/api/webhooks/sentinelgate
API_PUBLIC_URL=http://localhost:3001
# Or set callback explicitly:
# SENTINELGATE_CALLBACK_URL=https://api.example.com/api/webhooks/sentinelgate
SENTINELGATE_SUCCESS_URL=http://localhost:3000/wallet/deposit/success
SENTINELGATE_CANCEL_URL=http://localhost:3000/wallet/deposit/cancel
# Optional: override checkout currency (default USD; SentinelGate supports USD, GHS, KES, etc.)
# SENTINELGATE_CURRENCY=GHS
# SENTINELGATE_BASE_URL=https://sentinelgate.biz

# Client demo with SentinelGate: use .env.demo.example (PAYMENT_SIMULATION_INSTANT=false)
# Local webhooks: expose API with ngrok and set SENTINELGATE_CALLBACK_URL, or use webhook.site
# Then: npm run seed:demo  →  demo@prolinexgoal.demo / DemoGoal26!

# Manual provider webhook (if not using SentinelGate)
PAYMENT_WEBHOOK_SECRET=
PAYMENT_BASE_URL=

# Production — see .env.production.example and Dockerfile / docker-entrypoint.sh
NODE_ENV=production
# ENABLE_SWAGGER=false                 # Swagger off in production by default

# Admin / scaling
ADMIN_API_KEY=
REDIS_URL=
GAME_ENGINE_ENABLED=

